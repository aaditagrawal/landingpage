---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";

interface Props {
	title: string;
}

const { title } = Astro.props;

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '/index.html';

const navItems = [
	{ href: "/", label: "about", active: isHome },
	{ href: "/experience/", label: "experience", active: currentPath.startsWith('/experience') },
	{ href: "/projects/", label: "projects", active: currentPath.startsWith('/projects') },
	{ href: "/research/", label: "research", active: currentPath.startsWith('/research') },
	{ href: "/skills/", label: "skills", active: currentPath.startsWith('/skills') },
];
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Aadit Agrawal, Codex Creative at OpenAI and computer science engineer working across AI/ML, software engineering, HPC, and DevOps." />
		<meta name="viewport" content="width=device-width" />
		<meta name="theme-color" content="#0c0e0e" media="(prefers-color-scheme: dark)" />
		<meta name="theme-color" content="#f4f5f6" media="(prefers-color-scheme: light)" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<Font cssVariable="--font-dm-sans" preload />
		<Font cssVariable="--font-geist-mono" preload />

		<ClientRouter />

		<!-- Apply theme before first paint, and re-apply after client-side swaps. -->
		<script is:inline>
			(() => {
				const apply = () =>
					document.documentElement.setAttribute(
						"data-theme",
						localStorage.getItem("theme") || "dark",
					);
				apply();
				document.addEventListener("astro:after-swap", apply);
			})();
		</script>
	</head>
	<body>
		<div class="page">
			<header class="masthead">
				<a href="/" class="wordmark font-mono">aadit agrawal</a>
				<div class="masthead-right">
					<nav class="nav font-mono" aria-label="Site">
						{navItems.map((item) => (
							<a
								href={item.href}
								class:list={["nav-link", { active: item.active }]}
							>
								{item.label}
							</a>
						))}
						<a href="/resume.pdf" target="_blank" rel="noopener noreferrer" class="nav-link nav-link--resume" data-resume-open>resume</a>
					</nav>
					<button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
						<div class="toggle-track">
							<div class="toggle-thumb"></div>
						</div>
					</button>
				</div>
			</header>

			<main class="content">
				<slot />
			</main>

			<footer class="site-footer">
				<nav class="footer-links font-mono" aria-label="Contact and links">
					<a href="mailto:mail@aaditagrawal.com">mail@aaditagrawal.com</a>
					<a href="https://github.com/aaditagrawal">github</a>
					<a href="https://git.aadit.cc/aadit">git.aadit.cc</a>
					<a href="https://linkedin.com/in/aadit-agrawal">linkedin</a>
					<a href="https://blog.aadit.cc">blog.aadit.cc</a>
					<a href="/resume.pdf" target="_blank" rel="noopener noreferrer" data-resume-open>resume.pdf</a>
				</nav>
			</footer>
		</div>

		<dialog id="resume-dialog" class="resume-dialog" aria-labelledby="resume-dialog-title">
			<div class="resume-dialog__inner">
				<button type="button" class="resume-dialog__close font-mono" aria-label="close" data-resume-close>close</button>
				<h2 id="resume-dialog-title" class="resume-dialog__title">pick your flavor.</h2>
				<p class="resume-dialog__subtitle">same content, tuned for the reader. agents: see <a href="/llms.txt" class="resume-dialog__link font-mono">/llms.txt</a>.</p>
				<div class="resume-dialog__options">
					<a href="/resume.pdf" target="_blank" rel="noopener noreferrer" class="resume-option" data-resume-close>
						<span class="resume-option__label font-mono">human friendly</span>
						<span class="resume-option__desc">typeset, designed for people.</span>
					</a>
					<a href="/resume-ats.pdf" target="_blank" rel="noopener noreferrer" class="resume-option" data-resume-close>
						<span class="resume-option__label font-mono">agent friendly</span>
						<span class="resume-option__desc">plain-text ATS, parser-ready.</span>
					</a>
				</div>
			</div>
		</dialog>
	</body>
</html>

<style is:global>
	:root,
	[data-theme="dark"] {
		--bg: #0c0e0e;
		--surface: #101212;
		--surface-raised: #16191a;
		--border: #1c1f1f;
		--border-visible: #2b2f2f;
		--text-disabled: #5c615f;
		--text-secondary: #949a97;
		--text-primary: #e3e6e3;
		--text-display: #f5f7f4;

		/* One accent, used identically everywhere. */
		--accent: #576BFF;
		--accent-strong: #6e80ff;
		--accent-subtle: rgba(87, 107, 255, 0.15);
		--on-accent: #ffffff;

		/* Fonts: display and body in DM Sans, meta and labels in Geist Mono.
		   Self-hosted and preloaded via the Astro fonts pipeline; the variables
		   include metric-matched local fallbacks. */
		--font-sans: var(--font-dm-sans, system-ui, sans-serif);
		--font-mono: var(--font-geist-mono, ui-monospace, monospace);

		/* Spatial field: two dot scales (near, far) plus a faint accent glow */
		--dot-near: rgba(245, 247, 244, 0.09);
		--dot-far: rgba(245, 247, 244, 0.045);
		--field-glow: rgba(87, 107, 255, 0.07);

		--space-2xs: 0.125rem;
		--space-xs: 0.25rem;
		--space-sm: 0.5rem;
		--space-md: 1rem;
		--space-lg: 1.5rem;
		--space-xl: 2rem;
		--space-2xl: 3rem;
		--space-3xl: 4.5rem;

		--radius-xs: 4px;
		--radius-sm: 8px;
		--radius-md: 12px;
		--radius-lg: 16px;

		--dur-fast: 140ms;
		--dur-base: 240ms;
		--ease: cubic-bezier(0.22, 1, 0.36, 1);
	}

	[data-theme="light"] {
		--bg: #f4f5f6;
		--surface: #ffffff;
		--surface-raised: #eef0f2;
		--border: #e6e8ea;
		--border-visible: #ccd1d6;
		--text-disabled: #9aa0a6;
		--text-secondary: #5c636b;
		--text-primary: #1a1d21;
		--text-display: #0a0c0f;

		--accent: #4257e6;
		--accent-strong: #3346cc;
		--accent-subtle: rgba(87, 107, 255, 0.12);
		--on-accent: #ffffff;

		--dot-near: rgba(10, 12, 15, 0.11);
		--dot-far: rgba(10, 12, 15, 0.055);
		--field-glow: rgba(66, 87, 230, 0.06);
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		font-family: var(--font-sans);
		background: var(--bg);
		color: var(--text-primary);
		line-height: 1.5;
		scroll-behavior: smooth;
		-webkit-font-smoothing: antialiased;
		text-rendering: optimizeLegibility;
		font-size: clamp(15px, 0.25vw + 14.2px, 17px);
	}

	/* No background on body: html carries it, so the fixed field layers below
	   (negative z-index) stay visible between the canvas and the content. */
	body {
		min-height: 100dvh;
	}

	/* Spatial field, layer 1: two dot lattices (near, far) drifting very slowly.
	   Lives on html (not body) so client-side navigation, which swaps the body,
	   never restarts the animation mid-drift. The layer is oversized by one
	   84px tile in every direction so the loop wraps seamlessly; transform-only
	   animation stays on the compositor, so it costs no layout or paint work. */
	html::before {
		content: "";
		position: fixed;
		inset: -84px;
		z-index: -1;
		pointer-events: none;
		background-image:
			radial-gradient(var(--dot-near) 1px, transparent 1.5px),
			radial-gradient(var(--dot-far) 1px, transparent 1.5px);
		background-size: 84px 84px, 21px 21px;
		background-position: 0 0, 10.5px 10.5px;
		will-change: transform;
	}

	@media (prefers-reduced-motion: no-preference) {
		html::before {
			animation: field-drift 120s linear infinite;
		}
	}

	/* One full 84px tile per loop: both lattices map onto themselves, so the
	   restart is invisible. */
	@keyframes field-drift {
		from { transform: translate3d(0, 0, 0); }
		to { transform: translate3d(-84px, -84px, 0); }
	}

	/* Spatial field, layer 2: static accent glow plus a fade to the page
	   background toward the bottom, painted over the drifting dots. */
	html::after {
		content: "";
		position: fixed;
		inset: 0;
		z-index: -1;
		pointer-events: none;
		background-image:
			radial-gradient(ellipse 70% 45% at 50% -10%, var(--field-glow), transparent 70%),
			radial-gradient(ellipse 130% 100% at 50% 0%, transparent 30%, var(--bg) 92%);
	}

	/* ===== Page shell: one quiet column ===== */
	.page {
		max-width: 44rem;
		margin-inline: auto;
		min-height: 100dvh;
		display: flex;
		flex-direction: column;
		padding: clamp(1.75rem, 4vh, 3.5rem) 1.5rem 3rem;
	}

	.content {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: var(--space-3xl);
	}

	/* Navigation: a short, eased crossfade on the content. The masthead and
	   footer get their own transition groups so they hold steady (or glide to
	   their new position) instead of flashing with the page body. */
	::view-transition-old(root),
	::view-transition-new(root) {
		animation-duration: 180ms;
		animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
	}

	::view-transition-group(masthead),
	::view-transition-group(site-footer) {
		animation-duration: 220ms;
		animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
	}

	/* ===== Typography ===== */
	h1, h2, h3, h4, h5, h6 {
		font-family: var(--font-sans);
		color: var(--text-display);
		font-weight: 600;
		letter-spacing: -0.015em;
	}

	.font-mono {
		font-family: var(--font-mono);
		font-weight: 500;
	}

	a {
		color: var(--text-primary);
		text-decoration: none;
		transition: color var(--dur-fast) var(--ease), opacity var(--dur-fast) var(--ease);
	}

	a:hover {
		color: var(--accent);
	}

	a:active {
		opacity: 0.7;
	}

	button {
		cursor: pointer;
	}

	a,
	button {
		-webkit-tap-highlight-color: transparent;
	}

	:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
		border-radius: var(--radius-xs);
	}

	::selection {
		background: var(--accent);
		color: var(--on-accent);
	}

	/* ===== Masthead ===== */
	.masthead {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-md) var(--space-lg);
		margin-bottom: clamp(3.5rem, 9vh, 5.5rem);
		view-transition-name: masthead;
	}

	.wordmark {
		font-size: 0.875rem;
		color: var(--text-display);
		letter-spacing: -0.01em;
	}

	.masthead-right {
		display: flex;
		align-items: center;
		gap: var(--space-lg);
	}

	.nav {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-sm) var(--space-md);
	}

	.nav-link {
		position: relative;
		font-size: 0.75rem;
		color: var(--text-secondary);
		padding-bottom: var(--space-2xs);
	}

	.nav-link::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: 0;
		height: 1px;
		width: 100%;
		background: var(--accent);
		transform: scaleX(0);
		transform-origin: right;
		transition: transform var(--dur-base) var(--ease);
	}

	.nav-link:hover {
		color: var(--text-display);
	}

	.nav-link:hover::after {
		transform: scaleX(1);
		transform-origin: left;
	}

	.nav-link.active {
		color: var(--text-display);
	}

	.nav-link.active::after {
		transform: scaleX(1);
	}

	.nav-link--resume {
		color: var(--accent);
	}

	.nav-link--resume:hover {
		color: var(--accent-strong);
	}

	/* Theme toggle */
	.theme-toggle {
		background: none;
		border: none;
		display: flex;
		align-items: center;
		padding: var(--space-xs);
	}

	.toggle-track {
		width: 30px;
		height: 16px;
		background: var(--surface-raised);
		border: 1px solid var(--border-visible);
		border-radius: 999px;
		position: relative;
		transition: border-color var(--dur-base) var(--ease), background var(--dur-base) var(--ease);
	}

	.theme-toggle:hover .toggle-track {
		border-color: var(--accent);
	}

	.toggle-thumb {
		width: 10px;
		height: 10px;
		background: var(--text-secondary);
		border-radius: 50%;
		position: absolute;
		top: 2px;
		left: 2px;
		transition: transform var(--dur-base) var(--ease), background var(--dur-base) var(--ease);
	}

	.theme-toggle:hover .toggle-thumb {
		background: var(--accent);
	}

	.theme-toggle:active .toggle-thumb {
		transform: scale(0.8);
	}

	html[data-theme="light"] .toggle-thumb {
		transform: translateX(14px);
		background: var(--accent);
	}

	html[data-theme="light"] .theme-toggle:active .toggle-thumb {
		transform: translateX(14px) scale(0.8);
	}

	/* ===== Shared section pattern ===== */
	.section-title {
		font-family: var(--font-mono);
		font-weight: 500;
		font-size: 0.75rem;
		letter-spacing: 0.02em;
		color: var(--text-secondary);
		margin-bottom: var(--space-lg);
	}

	/* Dated entries (experience, research) */
	.entry-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-2xl);
	}

	.entry {
		display: grid;
		gap: var(--space-xs) var(--space-xl);
	}

	@media (min-width: 700px) {
		.entry {
			grid-template-columns: 8.5rem minmax(0, 1fr);
		}
	}

	.entry-when {
		font-family: var(--font-mono);
		font-weight: 500;
		font-size: 0.75rem;
		color: var(--text-disabled);
		padding-top: 0.25rem;
		white-space: nowrap;
	}

	.entry-body h3 {
		font-size: 1rem;
		margin-bottom: var(--space-sm);
		line-height: 1.4;
	}

	.entry-at {
		color: var(--text-secondary);
		font-weight: 400;
	}

	.entry-body ul {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.entry-body li,
	.entry-body > p {
		font-size: 0.9375rem;
		line-height: 1.65;
		color: var(--text-secondary);
	}

	/* ===== Footer ===== */
	.site-footer {
		margin-top: var(--space-3xl);
		padding-top: var(--space-lg);
		border-top: 1px solid var(--border);
		view-transition-name: site-footer;
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm) var(--space-lg);
		font-size: 0.75rem;
	}

	.footer-links a {
		color: var(--text-secondary);
	}

	.footer-links a:hover {
		color: var(--accent);
	}

	/* ===== Resume dialog ===== */
	.resume-dialog {
		padding: 0;
		border: 1px solid var(--border-visible);
		border-radius: var(--radius-md);
		background: var(--bg);
		color: var(--text-primary);
		max-width: min(420px, calc(100vw - var(--space-xl) * 2));
		width: 100%;
		margin: auto;
		position: fixed;
		inset: 0;
	}

	.resume-dialog::backdrop {
		background: rgba(0, 0, 0, 0.55);
		backdrop-filter: blur(4px);
	}

	[data-theme="light"] .resume-dialog::backdrop {
		background: rgba(40, 34, 28, 0.3);
	}

	.resume-dialog__inner {
		position: relative;
		padding: var(--space-xl);
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
	}

	.resume-dialog__close {
		position: absolute;
		top: var(--space-md);
		right: var(--space-md);
		background: none;
		border: none;
		color: var(--text-secondary);
		font-size: 0.6875rem;
		padding: 4px 6px;
	}

	.resume-dialog__close:hover {
		color: var(--accent);
	}

	.resume-dialog__title {
		font-size: 1.25rem;
		letter-spacing: -0.015em;
		line-height: 1.15;
	}

	.resume-dialog__subtitle {
		font-size: 0.875rem;
		color: var(--text-secondary);
		margin-bottom: var(--space-sm);
	}

	.resume-dialog__link {
		color: var(--text-primary);
		border-bottom: 1px dotted var(--border-visible);
	}

	.resume-dialog__link:hover {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}

	.resume-dialog__options {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.resume-option {
		display: flex;
		flex-direction: column;
		gap: 2px;
		padding: var(--space-md);
		border: 1px solid var(--border-visible);
		border-radius: var(--radius-sm);
		background: var(--surface);
		color: var(--text-primary);
		transition: border-color var(--dur-base) var(--ease), background var(--dur-base) var(--ease), transform var(--dur-base) var(--ease);
	}

	.resume-option:hover,
	.resume-option:focus-visible {
		border-color: var(--accent);
		background: var(--surface-raised);
		transform: translateY(-2px);
	}

	.resume-option:active {
		transform: translateY(0);
	}

	.resume-option__label {
		font-size: 0.75rem;
		letter-spacing: 0.02em;
		color: var(--accent);
	}

	.resume-option__desc {
		font-size: 0.8125rem;
		color: var(--text-secondary);
	}

	/* ===== Small screens ===== */
	@media (max-width: 540px) {
		.masthead-right {
			width: 100%;
			justify-content: space-between;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		*,
		*::before,
		*::after {
			animation-duration: 1ms !important;
			animation-iteration-count: 1 !important;
			transition-duration: 1ms !important;
			scroll-behavior: auto !important;
		}
	}
</style>

<script is:inline>
	(() => {
		// Re-wire on every navigation: astro:page-load fires on initial load and
		// after each client-side swap, when the new DOM is in place.
		const wire = () => {
			const root = document.documentElement;

			document.getElementById('theme-toggle')?.addEventListener('click', () => {
				const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
				localStorage.setItem('theme', next);
				root.setAttribute('data-theme', next);
			});

			// Resume dialog: any [data-resume-open] opens the chooser; falls back to the PDF link.
			const dialog = document.getElementById('resume-dialog');
			if (!dialog) return;

			document.querySelectorAll('[data-resume-open]').forEach((trigger) => {
				trigger.addEventListener('click', (event) => {
					if (typeof dialog.showModal === 'function') {
						event.preventDefault();
						dialog.showModal();
					}
				});
			});

			dialog.addEventListener('click', (event) => {
				if (event.target === dialog) dialog.close();
			});

			dialog.querySelectorAll('[data-resume-close]').forEach((el) => {
				el.addEventListener('click', () => setTimeout(() => dialog.close(), 0));
			});
		};

		document.addEventListener('astro:page-load', wire);
	})();
</script>

<script is:inline define:vars={{ prod: import.meta.env.PROD }}>
	// Offline cache and instant repeat visits; registered after load so it
	// never competes with first-paint resources.
	if (prod && 'serviceWorker' in navigator) {
		addEventListener('load', () => navigator.serviceWorker.register('/sw.js'));
	}
</script>
