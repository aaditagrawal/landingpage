</style>

<script is:inline defer>
	// Theme handling
	const themeToggle = document.getElementById('theme-toggle');
	const html = document.documentElement;

	const updateTheme = (isDark) => {
		html.setAttribute('data-theme', isDark ? 'dark' : 'light');
		localStorage.setItem('theme', isDark ? 'dark' : 'light');
	};

	// Initialize theme
	const savedTheme = localStorage.getItem('theme') || 'dark';
	updateTheme(savedTheme === 'dark');

	themeToggle?.addEventListener('click', () => {
		const isDark = html.getAttribute('data-theme') === 'dark';
		updateTheme(!isDark);
	});

	// Resume dialog
	const setupResumeDialog = () => {
		const dialog = document.getElementById('resume-dialog');
		const trigger = document.getElementById('resume-trigger');
		if (!dialog || !trigger || dialog.dataset.bound === '1') return;
		dialog.dataset.bound = '1';

		trigger.addEventListener('click', () => {
			if (typeof dialog.showModal === 'function') {
				dialog.showModal();
			} else {
				dialog.setAttribute('open', '');
			}
		});

		dialog.addEventListener('click', (event) => {
			if (event.target === dialog) dialog.close();
		});

		dialog.querySelectorAll('[data-resume-close]').forEach((el) => {
			el.addEventListener('click', () => {
				setTimeout(() => dialog.close(), 0);
			});
		});
	};

	// Detect if left-panel content is clipped (e.g. browser zoom) and show indicator
	const setupNavClipIndicator = () => {
		const panel = document.querySelector('.left-panel');
		if (!panel || panel.dataset.clipBound === '1') return;
		panel.dataset.clipBound = '1';

		const EPSILON = 2;
		const update = () => {
			const clipped = panel.scrollHeight - panel.clientHeight > EPSILON;
			panel.classList.toggle('is-clipped', clipped);
			const atBottom = panel.scrollTop + panel.clientHeight >= panel.scrollHeight - EPSILON;
			panel.classList.toggle('is-at-bottom', atBottom);
		};

		update();
		panel.addEventListener('scroll', update, { passive: true });
		window.addEventListener('resize', update);
		if (typeof ResizeObserver !== 'undefined') {
			new ResizeObserver(update).observe(panel);
		}
	};

	setupResumeDialog();
	setupNavClipIndicator();
</script>
