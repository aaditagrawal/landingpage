<script is:inline defer>
	// Theme handling
	const themeToggle = document.getElementById('theme-toggle');
	const root = document.documentElement;

	const updateTheme = (isDark) => {
		root.setAttribute('data-theme', isDark ? 'dark' : 'light');
		localStorage.setItem('theme', isDark ? 'dark' : 'light');
	};

	updateTheme((localStorage.getItem('theme') || 'dark') === 'dark');

	themeToggle?.addEventListener('click', () => {
		updateTheme(root.getAttribute('data-theme') !== 'dark');
	});

	// Resume dialog — any [data-resume-open] opens the chooser; falls back to the PDF link.
	const dialog = document.getElementById('resume-dialog');
	if (dialog) {
		document.querySelectorAll('[data-resume-open]').forEach((trigger) => {
			trigger.addEventListener('click', (event) => {
				if (typeof dialog.showModal === 'function') {
					event.preventDefault();
					dialog.showModal();
				}
			});
		});

		dialog.addEventListener('click', (event) => {
			if (event.target === dialog) dialog.close();
		});

		dialog.querySelectorAll('[data-resume-close]').forEach((el) => {
			el.addEventListener('click', () => setTimeout(() => dialog.close(), 0));
		});
	}
</script>
