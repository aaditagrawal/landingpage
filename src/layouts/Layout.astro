---
import { Picture } from "astro:assets";
import { join } from "node:path";
import pfp from "../assets/pfp.png";
import { iconDataUrl, roundIcon } from "../lib/roundIcon";

interface Props {
	title: string;
}

const { title } = Astro.props;

const pfpPath = join(process.cwd(), "src/assets/pfp.png");
const [favicon32, appleTouchIcon] = await Promise.all([
	roundIcon(pfpPath, 32),
	roundIcon(pfpPath, 180),
]);
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '/index.html';

const navItems = [
	{ href: "/", label: "/about", active: isHome },
	{ href: "/experience/", label: "/experience", active: currentPath.startsWith('/experience') },
	{ href: "/projects/", label: "/projects", active: currentPath.startsWith('/projects') },
	{ href: "/research/", label: "/research", active: currentPath.startsWith('/research') },
	{ href: "/skills/", label: "/skills", active: currentPath.startsWith('/skills') },
];
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Aadit Agrawal, Codex Creative at OpenAI and computer science engineer working across AI/ML, software engineering, HPC, and DevOps." />
		<meta name="viewport" content="width=device-width" />
		<meta name="theme-color" content="#0c0e0e" media="(prefers-color-scheme: dark)" />
		<meta name="theme-color" content="#f4f5f6" media="(prefers-color-scheme: light)" />
		<link rel="icon" type="image/png" sizes="32x32" href={iconDataUrl(favicon32)} />
		<link rel="apple-touch-icon" sizes="180x180" href={iconDataUrl(appleTouchIcon)} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Resource hints: fonts load async so HTML/CSS paint first -->
		<link rel="dns-prefetch" href="https://fonts.googleapis.com" />
		<link rel="dns-prefetch" href="https://fonts.gstatic.com" />
		<link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<!-- DM Sans (body, UI), Geist Mono (titles, data, labels). -->
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Geist+Mono:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>
		<noscript>
			<link
				href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Geist+Mono:wght@400;500;600&display=swap"
				rel="stylesheet"
			/>
		</noscript>
	</head>
	<body class="dot-grid">
		<div class="site-wrapper">
			<aside class="left-panel">
				<header class="header">
					<div class="header-top">
						<button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
							<div class="toggle-track">
								<div class="toggle-thumb"></div>
							</div>
						</button>
					</div>

					<div class="hero">
						<Picture
							src={pfp}
							formats={["avif", "webp"]}
							widths={[56, 72, 96, 144, 216]}
							sizes="96px"
							alt="Aadit Agrawal"
							class="hero-avatar"
							width={96}
							height={96}
							loading="eager"
							decoding="async"
						/>
						<h1 class="font-name">Aadit Agrawal</h1>
						<p class="subtitle">student, infra, dev, ai stuff</p>
					</div>

					<div class="header-details">
						<dl class="status-grid">
							<div class="status-item">
								<dt class="label-text">Education</dt>
								<dd class="status-value font-mono">MIT Manipal '27</dd>
							</div>
							<div class="status-item">
								<dt class="label-text">Location</dt>
								<dd class="status-value font-mono">Bengaluru, India</dd>
							</div>
							<div class="status-item">
								<dt class="label-text">Résumé</dt>
								<dd class="status-value font-mono">
									<a href="/resume.pdf" target="_blank" rel="noopener noreferrer" class="status-resume" data-resume-open aria-label="view my resume">/resume.pdf <span aria-hidden="true">→</span></a>
								</dd>
							</div>
						</dl>

						<div class="contact-links font-mono">
							<a href="mailto:mail@aaditagrawal.com">mail@aaditagrawal.com</a>
							<a href="https://blog.aadit.cc">blog.aadit.cc</a>
							<a href="https://blog.ecitis.org">blog.ecitis.org</a>
						</div>

						<div class="socials">
							<a href="https://github.com/aaditagrawal" class="social-link" aria-label="GitHub">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.53 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
							</a>
							<a href="https://git.aadit.cc/aadit" class="social-link" aria-label="Git">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"></circle><circle cx="6" cy="6" r="3"></circle><path d="M13 6h3a2 2 0 0 1 2 2v7"></path><line x1="6" y1="9" x2="6" y2="21"></line></svg>
							</a>
							<a href="https://linkedin.com/in/aadit-agrawal" class="social-link" aria-label="LinkedIn">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
							</a>
						</div>
					</div>
				</header>
			</aside>

			<div class="right-panel">
				<nav class="index font-mono" aria-label="Site index">
					{navItems.map((item) => (
						<a
							href={item.href}
							class:list={["nav-link", { active: item.active }]}
						>
							{item.label}
						</a>
					))}
					<a href="/resume.pdf" target="_blank" rel="noopener noreferrer" class="nav-link nav-link--ext" data-resume-open aria-label="view my resume">/resume.pdf</a>
				</nav>
				<main class:list={["content", { "content--home": isHome }]}>
					<slot />
				</main>
			</div>
		</div>

		<dialog id="resume-dialog" class="resume-dialog" aria-labelledby="resume-dialog-title">
			<div class="resume-dialog__inner">
				<button type="button" class="resume-dialog__close font-mono" aria-label="close" data-resume-close>[ x ]</button>
				<div class="resume-dialog__header">
					<span class="label-text">Résumé</span>
					<div class="line"></div>
				</div>
				<h2 id="resume-dialog-title" class="resume-dialog__title">pick your flavor.</h2>
				<p class="resume-dialog__subtitle">same content, tuned for the reader. agents: see <a href="/llms.txt" class="resume-dialog__link font-mono">/llms.txt</a>.</p>
				<div class="resume-dialog__options">
					<a href="/resume.pdf" target="_blank" rel="noopener noreferrer" class="resume-option font-mono" data-resume-close>
						<span class="resume-option__label">[ human friendly ]</span>
						<span class="resume-option__desc">typeset, designed for people.</span>
					</a>
					<a href="/resume-ats.pdf" target="_blank" rel="noopener noreferrer" class="resume-option font-mono" data-resume-close>
						<span class="resume-option__label">[ agent friendly ]</span>
						<span class="resume-option__desc">plain-text ATS, parser-ready.</span>
					</a>
				</div>
			</div>
		</dialog>
	</body>
</html>

<style is:global>
	:root,
	[data-theme="dark"] {
		--black: #0c0e0e;
		--surface: #101212;
		--surface-raised: #16191a;
		--border: #1c1f1f;
		--border-visible: #2b2f2f;
		--text-disabled: #5c615f;
		--text-secondary: #949a97;
		--text-primary: #e3e6e3;
		--text-display: #f5f7f4;

		/* One accent, used identically everywhere (color consistency lock). */
		--accent: #576BFF;
		--accent-strong: #6e80ff;
		--accent-subtle: rgba(87, 107, 255, 0.15);
		--on-accent: #ffffff;

		/* Fonts — titles in Geist Mono, body in DM Sans */
		--font-sans: "DM Sans", system-ui, sans-serif;
		--font-mono: "Geist Mono", ui-monospace, "SFMono-Regular", monospace;

		/* Spacing — rem-based so they scale with the fluid html font-size */
		--space-2xs: 0.125rem;
		--space-xs: 0.25rem;
		--space-sm: 0.5rem;
		--space-md: 1rem;
		--space-lg: 1.5rem;
		--space-xl: 2rem;
		--space-2xl: 3rem;
		--space-3xl: 4rem;
		--space-4xl: 6rem;

		/* One radius system */
		--radius-xs: 4px;
		--radius-sm: 8px;
		--radius-md: 12px;
		--radius-lg: 16px;

		/* Motion — slower, smoother easing reads calmer than the old snap */
		--dur-fast: 140ms;
		--dur-base: 240ms;
		--dur-slow: 520ms;
		--ease: cubic-bezier(0.22, 1, 0.36, 1);
		--ease-out: cubic-bezier(0.16, 1, 0.3, 1);
	}

	[data-theme="light"] {
		--black: #f4f5f6;
		--surface: #ffffff;
		--surface-raised: #eef0f2;
		--border: #e6e8ea;
		--border-visible: #ccd1d6;
		--text-disabled: #9aa0a6;
		--text-secondary: #5c636b;
		--text-primary: #1a1d21;
		--text-display: #0a0c0f;

		--accent: #576BFF;
		--accent-strong: #4257e6;
		--accent-subtle: rgba(87, 107, 255, 0.12);
		--on-accent: #ffffff;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		font-family: var(--font-sans);
		background: var(--black);
		color: var(--text-primary);
		line-height: 1.5;
		scroll-behavior: smooth;
		-webkit-font-smoothing: antialiased;
		text-rendering: optimizeLegibility;
		/* Fluid base: 14px on small, scales up to 20px on large viewports. */
		font-size: clamp(14px, 0.45vw + 11.5px, 20px);
	}

	body {
		min-height: 100vh;
		display: flex;
		justify-content: center;
		align-items: center;
		padding: var(--space-xl);
	}

	/* Dot grid background, kept faint */
	.dot-grid {
		background-image: radial-gradient(circle, var(--border-visible) 1px, transparent 1px);
		background-size: 22px 22px;
		background-position: center top;
	}

	/* Framed shell — editorial split */
	.site-wrapper {
		width: 100%;
		min-height: calc(100vh - (var(--space-xl) * 2));
		background: var(--black);
		border: 1px solid var(--border-visible);
		border-radius: var(--radius-lg);
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1fr);
	}

	@media (min-width: 1024px) {
		.site-wrapper {
			/* Constant identity column, content takes the rest. Fill the viewport
			   height (no locked aspect, so tall screens never leave dead space). */
			grid-template-columns: 360px minmax(0, 1fr);
			width: min(100%, 1240px);
			height: calc(100dvh - var(--space-xl) * 2);
			min-height: 0;
		}
	}

	/* Corner accents */
	.site-wrapper::before,
	.site-wrapper::after {
		content: '';
		position: absolute;
		width: 9px;
		height: 9px;
		border: 1.5px solid var(--accent);
		z-index: 10;
		opacity: 0.85;
	}

	.site-wrapper::before {
		top: 7px;
		left: 7px;
		border-right: none;
		border-bottom: none;
		border-top-left-radius: var(--radius-xs);
	}

	.site-wrapper::after {
		bottom: 7px;
		right: 7px;
		border-left: none;
		border-top: none;
		border-bottom-right-radius: var(--radius-xs);
	}

	/* Typography — titles in Geist Mono, body in DM Sans */
	h1, h2, h3, h4, h5, h6 {
		font-family: var(--font-mono);
		color: var(--text-display);
		font-weight: 500;
		letter-spacing: -0.02em;
	}

	.font-display {
		font-family: var(--font-mono);
		font-weight: 600;
		letter-spacing: -0.02em;
	}

	.font-name {
		font-family: var(--font-mono);
		font-weight: 500;
		letter-spacing: -0.03em;
	}

	.font-mono {
		font-family: var(--font-mono);
		font-weight: 500;
	}

	.label-text {
		font-family: var(--font-mono);
		font-weight: 500;
		font-size: 0.6875rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--text-secondary);
	}

	a {
		color: var(--text-primary);
		text-decoration: none;
		transition: color var(--dur-fast) var(--ease), opacity var(--dur-fast) var(--ease);
	}

	a:hover {
		color: var(--accent);
	}

	a:active {
		opacity: 0.7;
	}

	button {
		cursor: pointer;
	}

	a,
	button {
		-webkit-tap-highlight-color: transparent;
	}

	:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
		border-radius: var(--radius-xs);
	}

	::selection {
		background: var(--accent);
		color: var(--on-accent);
	}

	/* ===== Left panel (identity column) ===== */
	.left-panel {
		padding: var(--space-2xl) var(--space-xl);
		border-right: 1px solid var(--border-visible);
		position: sticky;
		top: 0;
		height: 100%;
		min-width: 0;
		overflow-y: auto;
		display: flex;
		flex-direction: column;
		scrollbar-width: none;
	}

	.left-panel::-webkit-scrollbar {
		display: none;
	}

	.right-panel {
		overflow-y: auto;
		height: 100%;
		min-width: 0;
		scrollbar-width: none;
		display: flex;
		flex-direction: column;
	}

	.right-panel::-webkit-scrollbar {
		display: none;
	}

	.header {
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.header-top {
		display: flex;
		justify-content: flex-end;
		align-items: center;
		margin-bottom: var(--space-2xl);
	}

	/* Theme toggle */
	.theme-toggle {
		background: none;
		border: none;
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		cursor: pointer;
		padding: var(--space-xs);
	}

	.toggle-track {
		width: 34px;
		height: 18px;
		background: var(--surface-raised);
		border: 1px solid var(--border-visible);
		border-radius: 999px;
		position: relative;
		transition: border-color var(--dur-base) var(--ease), background var(--dur-base) var(--ease);
	}

	.theme-toggle:hover .toggle-track {
		border-color: var(--accent);
	}

	.toggle-thumb {
		width: 11px;
		height: 11px;
		background: var(--text-primary);
		border-radius: 50%;
		position: absolute;
		top: 2.5px;
		left: 3px;
		transition: transform var(--dur-base) var(--ease), background var(--dur-base) var(--ease);
	}

	.theme-toggle:hover .toggle-thumb {
		background: var(--accent);
	}

	.theme-toggle:active .toggle-thumb {
		transform: scale(0.8);
	}

	html[data-theme="light"] .toggle-thumb {
		transform: translateX(16px);
		background: var(--accent);
	}

	html[data-theme="light"] .theme-toggle:active .toggle-thumb {
		transform: translateX(16px) scale(0.8);
	}

	.hero {
		margin-bottom: var(--space-2xl);
	}

	.hero-avatar {
		width: 88px;
		height: 88px;
		border-radius: 50%;
		display: block;
		margin-bottom: var(--space-lg);
		border: 1px solid var(--border-visible);
		transition: transform var(--dur-base) var(--ease), border-color var(--dur-base) var(--ease);
	}

	.hero-avatar:hover {
		transform: scale(1.03) rotate(-2deg);
		border-color: var(--accent);
	}

	h1 {
		font-size: clamp(1.6rem, 2vw, 1.95rem);
		line-height: 1.1;
		margin-bottom: var(--space-sm);
	}

	.subtitle {
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		letter-spacing: 0.02em;
		line-height: 1.5;
		color: var(--text-secondary);
	}

	/* Stat list — borderless, editorial */
	.status-grid {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
		margin-bottom: var(--space-xl);
		padding-top: var(--space-lg);
		border-top: 1px solid var(--border);
	}

	.status-item {
		display: flex;
		flex-direction: column;
		gap: var(--space-2xs);
	}

	.status-value {
		font-size: 0.8125rem;
		color: var(--text-primary);
	}

	.status-resume {
		color: var(--text-primary);
		display: inline-flex;
		align-items: center;
		gap: var(--space-xs);
	}

	.status-resume span {
		color: var(--text-secondary);
		transition: transform var(--dur-base) var(--ease), color var(--dur-base) var(--ease);
	}

	.status-resume:hover span {
		transform: translateX(3px);
		color: var(--accent);
	}

	.contact-links {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
		margin-bottom: var(--space-lg);
		font-size: 0.8125rem;
	}

	.contact-links a {
		color: var(--text-secondary);
		width: fit-content;
	}

	.contact-links a:hover {
		color: var(--accent);
	}

	.socials {
		display: flex;
		gap: var(--space-md);
	}

	.social-link {
		color: var(--text-secondary);
		display: inline-flex;
		transition: color var(--dur-base) var(--ease), transform var(--dur-base) var(--ease);
	}

	.social-link:hover {
		color: var(--accent);
		transform: translateY(-2px);
	}

	.social-link:active {
		transform: translateY(0) scale(0.94);
	}

	/* Continuous left-to-right blue gradient glow on /resume.pdf links */
	.status-resume,
	.index .nav-link--ext {
		font-weight: 500;
		background: linear-gradient(
			100deg,
			var(--accent) 0%,
			#9fb0ff 50%,
			var(--accent) 100%
		);
		background-size: 200% 100%;
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
		color: transparent;
		filter: drop-shadow(0 0 7px rgba(87, 107, 255, 0.42));
		animation: avail-glow 3.6s linear infinite;
	}

	@keyframes avail-glow {
		from { background-position: 200% 0; }
		to { background-position: 0% 0; }
	}

	/* ===== Index (top nav of the content column) ===== */
	.index {
		position: sticky;
		top: 0;
		z-index: 5;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-md) var(--space-lg);
		padding: var(--space-lg) var(--space-2xl);
		background: color-mix(in srgb, var(--black) 88%, transparent);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		border-bottom: 1px solid var(--border-visible);
	}

	.nav-link {
		position: relative;
		font-size: 0.8125rem;
		color: var(--text-secondary);
		padding-bottom: var(--space-2xs);
		transition: color var(--dur-fast) var(--ease);
	}

	.nav-link::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: 0;
		height: 1.5px;
		width: 100%;
		background: var(--accent);
		transform: scaleX(0);
		transform-origin: right;
		transition: transform var(--dur-base) var(--ease);
	}

	.nav-link:hover {
		color: var(--text-display);
	}

	.nav-link:hover::after {
		transform: scaleX(1);
		transform-origin: left;
	}

	.nav-link.active {
		color: var(--text-display);
	}

	.nav-link.active::after {
		transform: scaleX(1);
	}

	.nav-link--ext {
		margin-left: auto;
		color: var(--text-disabled);
	}

	/* ===== Main content ===== */
	.content {
		padding: var(--space-2xl);
		display: flex;
		flex-direction: column;
		gap: var(--space-3xl);
		flex: 1;
	}

	/* Home is sparse: center it as a composed page, links pinned at the bottom */
	.content--home {
		justify-content: center;
		gap: var(--space-2xl);
	}

	@media (max-width: 1023px) {
		.content--home {
			justify-content: flex-start;
		}
	}

	.section-header {
		display: flex;
