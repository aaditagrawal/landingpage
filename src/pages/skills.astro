---
import Layout from "../layouts/Layout.astro";

const skillGroups = [
    {
        title: "Languages",
        items: [
            { name: "Python", desc: "Primary scripting, AI/ML pipelines, TUI development" },
            { name: "TypeScript / JS", desc: "Full-stack web apps, AST tooling, React/Next.js" },
            { name: "C / C++", desc: "Low-level systems, CUDA kernels, HPC optimization" },
            { name: "Rust", desc: "Memory-safe tooling, WASM compilation (Tauri)" },
            { name: "Go", desc: "Concurrent microservices, CLI development" },
            { name: "Zig", desc: "Systems programming" },
            { name: "Bash / Zsh", desc: "CI/CD automation, Unix environment scripting" },
            { name: "SQL", desc: "PostgreSQL schema design, advanced querying" },
            { name: "Java", desc: "Desktop app development (JavaFX), legacy systems" },
        ],
    },
    {
        title: "AI and HPC",
        items: [
            { name: "PyTorch & JAX", desc: "Deep learning model architecture, training, and fine-tuning" },
            { name: "Inference engines", desc: "vLLM, SGLang, llama.cpp, TensorRT-LLM" },
            { name: "CUDA & GPU", desc: "NVIDIA Blackwell/Hopper compute, kernel optimization" },
            { name: "Apple Silicon (MLX)", desc: "Unified memory ML acceleration on ARM64" },
            { name: "Computer vision", desc: "OpenCV, YOLO, edge inference (NVIDIA Jetson)" },
            { name: "Cluster management", desc: "Distributed CUDA, NCCL, RDMA networking" },
            { name: "NLP & LLM ops", desc: "Transformers, LoRA/QLoRA fine-tuning, agentic RAG" },
        ],
    },
    {
        title: "Infrastructure and DevOps",
        items: [
            { name: "Containerization", desc: "Docker, LXC" },
            { name: "Virtualization", desc: "Proxmox VE, KVM/QEMU, clustered hypervisors" },
            { name: "IaC & automation", desc: "Terraform, Ansible, GitHub Actions, CI/CD pipelines" },
            { name: "Networking", desc: "Tailscale (WireGuard), Nginx, Caddy, Cloudflare" },
            { name: "Observability", desc: "Grafana, Prometheus, Loki, OpenTelemetry" },
            { name: "OS & environments", desc: "Linux (Debian/Arch/RHEL), macOS (Darwin), POSIX" },
        ],
    },
    {
        title: "Web, Cloud and Databases",
        items: [
            { name: "Frameworks", desc: "Next.js, React, Astro, Svelte, Tailwind CSS" },
            { name: "Backend & runtimes", desc: "Node.js, Bun, FastAPI, tRPC, REST APIs" },
            { name: "Cross-platform", desc: "Electron, Electrobun, WebAssembly (WASM)" },
            { name: "Relational DBs", desc: "PostgreSQL (w/ pgvector), SQLite, Drizzle ORM" },
            { name: "NoSQL & vector", desc: "MongoDB, Redis, ChromaDB" },
            { name: "Cloud providers", desc: "AWS, GCP, Azure, Hetzner, Linode, Vercel, Cloudflare" },
        ],
    },
    {
        title: "System Architecture",
        items: [
            { name: "Instruction sets", desc: "ARM64 (Apple M-series, Jetson), AMD64/x86-64, RISC-V" },
            { name: "Optimization", desc: "SIMD vectorization, cross-compilation" },
        ],
    },
];
---

<Layout title="Skills | Aadit Agrawal">
    <section id="skills" class="section">
        <h2 class="section-title">skills</h2>

        <div class="skill-groups">
            {skillGroups.map((group) => (
                <div class="skill-group">
                    <h3>{group.title}</h3>
                    <div class="skill-grid">
                        {group.items.map((item) => (
                            <div class="skill-item">
                                <span class="skill-name font-mono">{item.name}</span>
                                <span class="skill-desc">{item.desc}</span>
                            </div>
                        ))}
                    </div>
                </div>
            ))}
        </div>
    </section>
</Layout>

<style>
    .skill-groups {
        display: flex;
        flex-direction: column;
        gap: var(--space-2xl);
    }

    .skill-group h3 {
        font-size: 1rem;
        margin-bottom: var(--space-lg);
    }

    .skill-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-lg) var(--space-2xl);
    }

    @media (min-width: 640px) {
        .skill-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    .skill-item {
        display: flex;
        flex-direction: column;
        gap: var(--space-2xs);
    }

    .skill-name {
        font-size: 0.8125rem;
        color: var(--text-primary);
    }

    .skill-desc {
        font-size: 0.875rem;
        line-height: 1.55;
        color: var(--text-secondary);
    }
</style>
