---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Skills | Aadit Agrawal">
    <section id="skills" class="section">
        <div class="section-header">
            <h2 class="label-text">TECHNICAL SKILLS MATRIX</h2>
            <div class="line"></div>
        </div>

        <div class="skills-container">
            <div class="skill-category">
                <div class="category-header">
                    <h3 class="font-display">PROGRAMMING LANGUAGES</h3>
                    <span class="label-text count">[09]</span>
                </div>
                <div class="skill-grid">
                    <div class="skill-item">
                        <span class="skill-name">Python</span>
                        <span class="skill-desc"
                            >Primary scripting, AI/ML pipelines, TUI development</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">TypeScript / JS</span>
                        <span class="skill-desc"
                            >Full-stack web apps, AST tooling, React/Next.js</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">C / C++</span>
                        <span class="skill-desc"
                            >Low-level systems, CUDA kernels, HPC optimization</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Rust</span>
                        <span class="skill-desc"
                            >Memory-safe tooling, WASM compilation (Tauri)</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Go</span>
                        <span class="skill-desc"
                            >Concurrent microservices, CLI development</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Zig</span>
                        <span class="skill-desc"
                            >Systems programming, drop-in C compiler replacement</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Bash / Zsh</span>
                        <span class="skill-desc"
                            >CI/CD automation, Unix environment scripting</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">SQL</span>
                        <span class="skill-desc"
                            >PostgreSQL schema design, advanced querying</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Java</span>
                        <span class="skill-desc"
                            >Desktop app development (JavaFX), legacy systems</span
                        >
                    </div>
                </div>
            </div>

            <div class="skill-category">
                <div class="category-header">
                    <h3 class="font-display">AI & HPC</h3>
                    <span class="label-text count">[07]</span>
                </div>
                <div class="skill-grid">
                    <div class="skill-item">
                        <span class="skill-name">PyTorch & JAX</span>
                        <span class="skill-desc"
                            >Deep learning model architecture, training, and
                            fine-tuning</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Inference Engines</span>
                        <span class="skill-desc"
                            >vLLM, SGLang, llama.cpp, TensorRT-LLM</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">CUDA & GPU</span>
                        <span class="skill-desc"
                            >NVIDIA Blackwell/Hopper compute, kernel
                            optimization</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Apple Silicon (MLX)</span>
                        <span class="skill-desc"
                            >Unified memory ML acceleration on ARM64</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Computer Vision</span>
                        <span class="skill-desc"
                            >OpenCV, YOLO, edge inference (NVIDIA Jetson)</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Cluster Management</span>
                        <span class="skill-desc"
                            >Distributed CUDA, NCCL, RDMA networking</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">NLP & LLM Ops</span>
                        <span class="skill-desc"
                            >Transformers, SGLang, vLLM, Llama.cpp, LoRA/QLoRA
                            fine-tuning, Agentic RAG</span
                        >
                    </div>
                </div>
            </div>

            <div class="skill-category">
                <div class="category-header">
                    <h3 class="font-display">INFRASTRUCTURE & DEVOPS</h3>
                    <span class="label-text count">[06]</span>
                </div>
                <div class="skill-grid">
                    <div class="skill-item">
                        <span class="skill-name">Containerization</span>
                        <span class="skill-desc"
                            >Docker, LXC</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Virtualization</span>
                        <span class="skill-desc"
                            >Proxmox VE, KVM/QEMU, clustered hypervisors</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">IaC & Automation</span>
                        <span class="skill-desc"
                            >Terraform, Ansible, GitHub Actions, CI/CD pipelines</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Networking</span>
                        <span class="skill-desc"
                            >Tailscale (WireGuard), Nginx, Caddy, Cloudflare</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Observability</span>
                        <span class="skill-desc"
                            >Grafana dashboards, Prometheus metrics, Loki logs, OpenTelemetry</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">OS & Environments</span>
                        <span class="skill-desc"
                            >Linux (Debian/Arch/RHEL), macOS (Darwin), POSIX</span
                        >
                    </div>
                </div>
            </div>

            <div class="skill-category">
                <div class="category-header">
                    <h3 class="font-display">WEB, CLOUD & DATABASES</h3>
                    <span class="label-text count">[06]</span>
                </div>
                <div class="skill-grid">
                    <div class="skill-item">
                        <span class="skill-name">Frameworks</span>
                        <span class="skill-desc"
                            >Next.js, React, Astro, Svelte, Tailwind CSS</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Backend & Runtimes</span>
                        <span class="skill-desc"
                            >Node.js, Bun, FastAPI, tRPC, REST APIs</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Cross-Platform</span>
                        <span class="skill-desc"
                            >Electron, Electrobun, WebAssembly (WASM)</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Relational DBs</span>
                        <span class="skill-desc"
                            >SQL, PostgreSQL (w/ pgvector), SQLite, Drizzle ORM</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">NoSQL & Vector</span>
                        <span class="skill-desc">MongoDB, Redis, ChromaDB</span>
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Cloud Providers</span>
                        <span class="skill-desc"
                            >AWS, GCP, Azure, Hetzner, Linode, Vercel, Cloudflare</span
                        >
                    </div>
                </div>
            </div>

            <div class="skill-category">
                <div class="category-header">
                    <h3 class="font-display">SYSTEM ARCHITECTURE</h3>
                    <span class="label-text count">[02]</span>
                </div>
                <div class="skill-grid">
                    <div class="skill-item">
                        <span class="skill-name">Instruction Sets</span>
                        <span class="skill-desc"
                            >ARM64 (Apple M-series, Jetson), AMD64/x86-64,
                            RISC-V</span
                        >
                    </div>
                    <div class="skill-item">
                        <span class="skill-name">Optimization</span>
                        <span class="skill-desc"
                            >SIMD vectorization, cross-compilation</span
                        >
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>

<style>
    .skills-container {
        display: flex;
        flex-direction: column;
        gap: var(--space-3xl);
    }

    .category-header {
        display: flex;
        align-items: baseline;
        gap: var(--space-sm);
        margin-bottom: var(--space-xl);
        padding-bottom: var(--space-sm);
        border-bottom: 1px solid var(--border);
    }

    .category-header h3 {
        font-size: 24px;
        color: var(--text-display);
        text-transform: uppercase;
        letter-spacing: -0.02em;
        margin: 0;
    }

    .category-header .count {
        color: var(--accent);
    }

    .skill-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1px;
        background: var(--border-visible);
        border: 1px solid var(--border-visible);
    }

    @media (min-width: 640px) {
        .skill-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (min-width: 1024px) {
        .skill-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .skill-item {
        display: flex;
        flex-direction: column;
        gap: var(--space-xs);
        padding: var(--space-lg);
        background: var(--black);
        transition: background-color var(--dur-base) ease;
        position: relative;
        overflow: hidden;
    }

    /* Fix border alignment on empty grid cells (by extending backgrounds) */
    .skill-item:last-child:nth-child(odd) {
        grid-column: 1 / -1;
    }

    @media (min-width: 640px) and (max-width: 1023px) {
        .skill-item:last-child:nth-child(odd) {
            grid-column: 1 / -1;
        }
    }

    @media (min-width: 1024px) {
        .skill-category:nth-child(1) .skill-item:last-child,
        .skill-category:nth-child(2) .skill-item:last-child,
        .skill-category:nth-child(3) .skill-item:last-child,
        .skill-category:nth-child(4) .skill-item:last-child {
            /* Reset for 3-column layout where 9, 6, 6 are clean multiples of 3, but 7 isn't */
            grid-column: auto;
        }

        /* Target the 7th item in AI_&_HPC grid specifically */
        .skill-category:nth-child(2) .skill-item:last-child {
            grid-column: 1 / span 3;
        }

        /* Target the 2 items in Architecture grid */
        .skill-category:nth-child(5) .skill-item:last-child {
            grid-column: 2 / span 2;
        }
    }

    .skill-item::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 1px;
        background: var(--accent);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform var(--dur-base) var(--ease);
    }

    .skill-item:hover {
        background: var(--surface);
    }

    .skill-item:hover::before {
        transform: scaleX(1);
    }

    .skill-name {
        font-family: "Geist Mono", monospace;
        font-weight: 600;
        font-size: 14px;
        color: var(--text-display);
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .skill-desc {
        font-size: 14px;
        color: var(--text-secondary);
        line-height: 1.5;
    }
</style>
