---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Aadit Agrawal | Computer Science Engineer">
    <section id="about" class="section">
        <div class="section-header">
            <h2 class="label-text">ABOUT</h2>
            <div class="line"></div>
        </div>

        <div class="about-content">
            <p>
                Hello! I'm trying to build cool stuff.
            </p>

            <p>
                Most of my projects are hobbyist OSS tools because that's my favorite thing to do - solve a simple problem with a bootstrapped solution.
            </p>

            <p>
                I love working on a bunch of things - devops/MLOps/dev stuff.
            </p>


            <div class="status-callout">
                Currently looking for <strong>Summer 2026</strong>, <strong>Winter 2026</strong> internships or any <strong>applied product/research</strong> roles across any technical vertical. I tend to learn fast.
            </div>
        </div>
    </section>
</Layout>

<style>
    .about-content {
        display: flex;
        flex-direction: column;
        gap: var(--space-lg);
        font-size: 19px;
        line-height: 1.65;
        color: var(--text-primary);
        max-width: 780px;
    }

    .about-content p {
        margin: 0;
    }

    .status-callout {
        margin-top: var(--space-md);
        padding: var(--space-md) var(--space-lg);
        background: var(--surface);
        border: 1px solid var(--border-visible);
        border-left: 3px solid var(--accent);
        border-radius: var(--radius-sm);
        font-size: 17px;
        line-height: 1.55;
        color: var(--text-display);
    }

    .status-callout strong {
        font-weight: 600;
        color: var(--accent);
    }
</style>
