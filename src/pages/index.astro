---
import { Picture } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import pfp from "../assets/pfp.png";
---

<Layout title="Aadit Agrawal | Codex Creative, Student, Infra, Dev, AI Stuff">
    <section id="about" class="intro">
        <div class="identity">
            <Picture
                src={pfp}
                formats={["avif", "webp"]}
                widths={[56, 72, 96, 144]}
                sizes="56px"
                alt="Aadit Agrawal"
                class="avatar"
                width={56}
                height={56}
                loading="eager"
                decoding="async"
                fetchpriority="high"
            />
            <div class="identity-text">
                <h1>Aadit Agrawal</h1>
                <p class="identity-meta font-mono">mit manipal '27 · bengaluru, india</p>
            </div>
        </div>

        <h2 class="statement">I like figuring out tech by making things with it.</h2>

        <div class="intro-body">
            <p>
                I'm a CS student at MIT Manipal and Codex Creative at OpenAI.
            </p>
            <p>
                I grew up on science fiction. Asimov, Sagan, Andy Weir.
                Science, and optimism about it.
            </p>
        </div>
    </section>

    <section id="now" class="section">
        <h2 class="section-title">currently</h2>
        <ul class="plain-list">
            <li>
                <a href="/experience/">Codex Creative at OpenAI</a>, driving
                Codex adoption for dev and knowledge work in India.
            </li>
            <li>
                <a href="https://ecitis.org">Head Student Researcher at CASIR, MAHE</a>,
                running an on-prem HPC stack and a 4× Mac Studio inference cluster.
            </li>
            <li>
                <a href="https://theprism.fyi">Founding President of PRISM</a>,
                a 150+ member research club at MIT Manipal.
            </li>
        </ul>
    </section>

    <section id="work" class="section">
        <h2 class="section-title">selected work</h2>
        <ul class="plain-list">
            <li>
                <a href="https://fc2.coolstuff.work">The TIK Menu &amp; Campus Suite</a>,
                campus food and utilities used by 5,000+ people daily.
            </li>
            <li>
                <a href="https://cloud.aadit.cc">Homelab infrastructure</a>,
                70+ self-hosted services at 98% uptime since 2022.
            </li>
            <li>
                <a href="https://coolstuff.work">coolstuff.work</a>,
                small tools for peers with 10,000+ aggregate daily users.
            </li>
        </ul>
        <p class="more">
            the longer story is in <a href="/projects/">/projects</a> and
            <a href="/experience/">/experience</a>. or just say hi.
        </p>
    </section>
</Layout>

<style>
    .intro {
        display: flex;
        flex-direction: column;
        gap: var(--space-xl);
    }

    .identity {
        display: flex;
        align-items: center;
        gap: var(--space-md);
    }

    .avatar {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        display: block;
        border: 1px solid var(--border-visible);
        transition: transform var(--dur-base) var(--ease), border-color var(--dur-base) var(--ease);
    }

    .avatar:hover {
        transform: scale(1.04) rotate(-2deg);
        border-color: var(--accent);
    }

    .identity-text h1 {
        font-size: 1.125rem;
        line-height: 1.2;
        margin-bottom: var(--space-2xs);
    }

    .identity-meta {
        font-size: 0.75rem;
        color: var(--text-secondary);
    }

    .statement {
        font-size: clamp(1.625rem, 4vw, 2.25rem);
        line-height: 1.2;
        letter-spacing: -0.025em;
        max-width: 20ch;
        margin-top: var(--space-sm);
    }

    .intro-body {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
        max-width: 52ch;
        font-size: 1rem;
        line-height: 1.7;
        color: var(--text-secondary);
    }

    .plain-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
        max-width: 56ch;
    }

    .plain-list li {
        font-size: 0.9375rem;
        line-height: 1.65;
        color: var(--text-secondary);
    }

    .plain-list a {
        color: var(--text-primary);
    }

    .plain-list a:hover {
        color: var(--accent);
    }

    .more {
        margin-top: var(--space-lg);
        font-size: 0.9375rem;
        color: var(--text-secondary);
    }

    .more a {
        color: var(--text-primary);
    }

    .more a:hover {
        color: var(--accent);
    }
</style>
