---
import Layout from "../layouts/Layout.astro";

type HeatmapPoint = { timestamp: number; contributions: number };

const MONTHS = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
const DAY_MS = 86_400_000;

function scoreFor(count: number): 0 | 1 | 2 | 3 | 4 {
    if (count === 0) return 0;
    if (count <= 2) return 1;
    if (count <= 5) return 2;
    if (count <= 10) return 3;
    return 4;
}

function buildGiteaSvg(data: HeatmapPoint[]): string {
    const counts = new Map<string, number>();
    for (const { timestamp, contributions } of data) {
        const key = new Date(timestamp * 1000).toISOString().slice(0, 10);
        counts.set(key, (counts.get(key) ?? 0) + contributions);
    }

    const WEEKS = 53;
    const CELL = 10;
    const STEP = 12;
    const LEFT_PAD = 27;
    const TOP_PAD = 20;

    const today = new Date();
    const endMs = Date.UTC(today.getUTCFullYear(), today.getUTCMonth(), today.getUTCDate());
    const endDow = new Date(endMs).getUTCDay();
    const startMs = endMs - endDow * DAY_MS - (WEEKS - 1) * 7 * DAY_MS;

    const rects: string[] = [];
    const labels: string[] = [];
    let lastLabeledMonth = -1;

    for (let w = 0; w < WEEKS; w++) {
        for (let dow = 0; dow < 7; dow++) {
            const ms = startMs + (w * 7 + dow) * DAY_MS;
            if (ms > endMs) break;
            const d = new Date(ms);
            const key = d.toISOString().slice(0, 10);
            const level = scoreFor(counts.get(key) ?? 0);
            const x = LEFT_PAD + w * STEP;
            const y = TOP_PAD + dow * STEP;
            rects.push(`<rect data-score="${level}" x="${x}" y="${y}" width="${CELL}" height="${CELL}"/>`);

            if (dow === 0) {
                const month = d.getUTCMonth();
                if (month !== lastLabeledMonth) {
                    lastLabeledMonth = month;
                    labels.push(`<text x="${x}" y="10">${MONTHS[month]}</text>`);
                }
            }
        }
    }

    const width = LEFT_PAD + WEEKS * STEP;
    const height = TOP_PAD + 7 * STEP;

    return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${width} ${height}" width="${width}" height="${height}" role="img" aria-label="Gitea contribution graph">${labels.join("")}${rects.join("")}</svg>`;
}

let githubSvg = "";
try {
    const res = await fetch("https://ghchart.rshah.org/576BFF/aaditagrawal");
    if (res.ok) {
        githubSvg = (await res.text())
            .replace(/<svg([^>]*)width="\d+"([^>]*)height="\d+"/, '<svg$1viewBox="0 0 663 104"$2');
    }
} catch {
    // build-time fetch failed; section will be omitted
}

let giteaSvg = "";
try {
    const res = await fetch("https://git.aadit.cc/api/v1/users/aadit/heatmap");
    if (res.ok) {
        const data = (await res.json()) as HeatmapPoint[];
        giteaSvg = buildGiteaSvg(data);
    }
} catch {
    // build-time fetch failed; section will be omitted
}
---

<Layout title="Experience | Aadit Agrawal">
    {(githubSvg || giteaSvg) && (
        <section id="activity" class="section section--activity">
            <div class="section-header">
                <h2 class="label-text">ACTIVITY</h2>
                <div class="line"></div>
            </div>

            <div class="activity-stack">
                {githubSvg && (
                    <a
                        href="https://github.com/aaditagrawal"
                        class="activity"
                        aria-label="View GitHub profile"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <div class="activity__chart activity__chart--gh" set:html={githubSvg} />
                        <span class="activity__caption font-mono">github.com/aaditagrawal ↗</span>
                    </a>
                )}

                {giteaSvg && (
                    <a
                        href="https://git.aadit.cc/aadit"
                        class="activity"
                        aria-label="View Gitea profile"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <div class="activity__chart activity__chart--gt" set:html={giteaSvg} />
                        <span class="activity__caption font-mono">git.aadit.cc/aadit ↗</span>
                    </a>
                )}
            </div>
        </section>
    )}

    <section id="experience" class="section">
        <div class="section-header">
            <h2 class="label-text">EXPERIENCE</h2>
            <div class="line"></div>
        </div>

        <div class="exp-list">
            <article class="exp-card">
                <div class="exp-header">
                    <h3>
                        Head Student Researcher <span class="exp-at"
                            >@ <a href="https://ecitis.org">CASIR, MAHE</a></span>
                    </h3>
                    <span class="label-text font-mono">MAY 2025—PRES</span>
                </div>
                <ul>
                    <li>
                        Architected an on-prem HPC stack (96-core Threadripper
                        7995WX, 48GB A6000, 256GB RAM) serving 1,500+ daily
                        inference requests at 99.2% uptime.
                    </li>
                    <li>
                        Leading setup of a $200K+ compute cluster pairing Apple
                        Silicon with NVIDIA Blackwell, tuned for mixed ARM64 +
                        CUDA workloads.
                    </li>
                    <li>
                        Real-time computer vision on NVIDIA Jetson carried on
                        DJI drones — 30fps edge inference over RTMP.
                    </li>
                    <li>
                        LLM semantic translator for Schneider Electric — IEC
                        61131-3 to IEC 61499 automation for legacy PLC
                        codebases; cut migration effort by about 70%.
                    </li>
                    <li>
                        Technical document ingestion for machine and
                        electronics engineering support — evolved from RAG +
                        BM25 + keyword clusters to trigram indices with custom
                        pi.dev search agents; VLM + LLM stack across 2,000+
                        docs at 94% accuracy, roughly 3× faster than the prior
                        approach.
                    </li>
                    <li>
                        Application security analysis platform (Schneider
                        Electric) — source and compiled-binary evaluation in
                        computer-use sandboxes with OS state monitoring (registry
                        / DLL deltas), pattern-matched to a correlated CVE / CWE
                        / MITRE index; pentest lead time from three weeks to
                        three days.
                    </li>
                    <li>
                        Shipped three production AI systems; two peer-reviewed
                        publications in progress; team write-ups on <a
                            href="https://blog.ecitis.org">blog.ecitis.org</a>.
                    </li>
                </ul>
            </article>

            <article class="exp-card">
                <div class="exp-header">
                    <h3>
                        DevOps Engineer, Intern <span class="exp-at"
                            >@ Pixa AI, Bengaluru</span>
                    </h3>
                    <span class="label-text font-mono">DEC 2025</span>
                </div>
                <ul>
                    <li>
                        Provisioned GPU compute (H100/H200/B200) and CI/CD for
                        Phi-4 TTS/STT fine-tuning; 99.5% deployment success
                        across two API releases.
                    </li>
                </ul>
            </article>

            <article class="exp-card">
                <div class="exp-header">
                    <h3>
                        Frontend Engineer <span class="exp-at"
                            >@ <a href="https://rossmanngroup.com"
                                >Rossmann New Media 2 Inc.</a
                            ></span>
                    </h3>
                    <span class="label-text font-mono">JAN 2026—PRES</span>
                </div>
                <ul>
                    <li>
                        Migrated rossmanngroup.com from WordPress to Next.js;
                        improved load performance and cross-platform
                        responsiveness.
                    </li>
                    <li>
                        Technical SEO overhaul on data-recovery keywords —
                        moved primary rankings from 100+ into the top 5.
                    </li>
                </ul>
                <div class="exp-header exp-header--sub">
                    <h3>
                        Freelance Graphic Designer
                    </h3>
                    <span class="label-text font-mono">2022—2024</span>
                </div>
                <ul>
                    <li>
                        Designed select thumbnails and merch designs.
                    </li>
                </ul>
            </article>

            <article class="exp-card">
                <div class="exp-header">
                    <h3>
                        Founding President <span class="exp-at"
                            >@ <a href="https://theprism.fyi">PRISM</a></span>
                    </h3>
                    <span class="label-text font-mono">JAN 2026—PRES</span>
                </div>
                <ul>
                    <li>
                        Research club spanning AI/ML, software engineering,
                        HPC, DevOps, biotech, and infosec — 150+ members.
                    </li>
                    <li>
                        Academic Advisory Board for AI curriculum and adoption
                        at MAHE.
                    </li>
                </ul>
            </article>

            <article class="exp-card">
                <div class="exp-header">
                    <h3>
                        Management Committee <span class="exp-at"
                            >@ MIST (Cybersecurity Club)</span>
                    </h3>
                    <span class="label-text font-mono">OCT 2023—JUN 2025</span>
                </div>
                <ul>
                    <li>
                        CTF infrastructure for 300+ users at 100% uptime; cut
                        operating costs by 80%.
                    </li>
                    <li>
                        Ran 12+ workshops for 150+ participants; teams placed
                        in the top 10% nationally at CTF competitions.
                    </li>
                </ul>
            </article>
        </div>
    </section>
</Layout>

<style>
    ul {
        list-style: none;
        padding-left: var(--space-sm);
    }

    li {
        position: relative;
        font-size: 0.9375rem;
        color: var(--text-secondary);
        margin-bottom: var(--space-sm);
        line-height: 1.6;
        padding-left: var(--space-md);
    }

    li::before {
        content: "▪";
        position: absolute;
        left: 0;
        color: var(--text-disabled);
        font-size: 12px;
    }

    .exp-header--sub {
        margin-top: var(--space-md);
    }

    .exp-header--sub h3 {
        font-size: 0.9375rem;
        color: var(--text-primary);
        font-weight: 500;
    }

    .section--activity {
        content-visibility: auto;
        contain-intrinsic-size: 0 320px;
    }

    .activity-stack {
        display: grid;
        gap: var(--space-lg) var(--space-xl);
        grid-template-columns: 1fr;
    }

    @media (min-width: 720px) {
        .activity-stack {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    .activity {
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
        color: var(--text-secondary);
        min-width: 0;
    }

    .activity__chart {
        overflow-x: auto;
        scrollbar-width: none;
    }

    .activity__chart::-webkit-scrollbar {
        display: none;
    }

    .activity__chart :global(svg) {
        display: block;
        width: 100%;
        height: auto;
        min-width: 480px;
    }

    .activity__chart :global(rect[data-score="0"]) { fill: var(--surface-raised) !important; }
    .activity__chart :global(rect[data-score="1"]) { fill: rgba(87, 107, 255, 0.30) !important; }
    .activity__chart :global(rect[data-score="2"]) { fill: rgba(87, 107, 255, 0.55) !important; }
    .activity__chart :global(rect[data-score="3"]) { fill: rgba(87, 107, 255, 0.80) !important; }
    .activity__chart :global(rect[data-score="4"]) { fill: var(--accent) !important; }

    /* Boost lower-score sensitivity on the GitHub chart so light activity reads more clearly */
    .activity__chart--gh :global(rect[data-score="1"]) { fill: rgba(87, 107, 255, 0.50) !important; }
    .activity__chart--gh :global(rect[data-score="2"]) { fill: rgba(87, 107, 255, 0.72) !important; }
    .activity__chart--gh :global(rect[data-score="3"]) { fill: rgba(87, 107, 255, 0.90) !important; }

    .activity__chart--gh :global(text):not([y="10"]) {
        display: none !important;
    }
    .activity__chart--gh :global(text[y="10"]) {
        fill: var(--text-secondary) !important;
        font-family: "Geist Mono", monospace !important;
        font-size: 9px !important;
        letter-spacing: 0.04em;
    }

    .activity__chart--gt :global(text) {
        fill: var(--text-secondary);
        font-family: "Geist Mono", monospace;
        font-size: 9px;
        letter-spacing: 0.04em;
    }

    .activity__caption {
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-secondary);
        transition: color var(--dur-base) ease;
    }

    .activity:hover .activity__caption {
        color: var(--accent);
    }
</style>
