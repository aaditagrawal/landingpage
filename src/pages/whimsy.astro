---
import TravelMap from "../components/TravelMap.astro";
import Layout from "../layouts/Layout.astro";
import { bookSections } from "../data/books";
import { musicSections } from "../data/music";
---

<Layout title="Whimsy | Aadit Agrawal">
	<section id="whimsy" class="intro">
		<h2 class="statement">Off-clock things I keep coming back to.</h2>
		<p class="intro-body">
			Places I've been, books that stuck, music on repeat, and other bits that don't fit a résumé.
		</p>
	</section>

	<TravelMap />

	<section id="books" class="section">
		<h2 class="section-title">books</h2>

		{bookSections.map((section) => (
			<div class="book-section">
				<h3 class="book-section__label font-mono">{section.label}</h3>
				<ul class="book-list">
					{section.books.map((book) => (
						<li class="book-list__item">
							<span class="book-list__title">{book.title}</span>
							<span class="book-list__author font-mono">{book.author}</span>
							{book.note && <span class="book-list__note">{book.note}</span>}
						</li>
					))}
				</ul>
			</div>
		))}
	</section>

	<section id="music" class="section">
		<h2 class="section-title">music</h2>

		{musicSections.map((section) => (
			<div class="book-section">
				<h3 class="book-section__label font-mono">{section.label}</h3>
				<ul class="book-list">
					{section.tracks.map((track) => (
						<li class="book-list__item">
							<span class="book-list__title">{track.title}</span>
							<span class="book-list__author font-mono">{track.artist}</span>
							{track.note && <span class="book-list__note">{track.note}</span>}
						</li>
					))}
				</ul>
			</div>
		))}
	</section>
</Layout>

<style>
	.intro {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
		max-width: 52ch;
	}

	.statement {
		font-size: clamp(1.625rem, 4vw, 2.25rem);
		line-height: 1.2;
		letter-spacing: -0.025em;
		max-width: 22ch;
	}

	.intro-body {
		font-size: 1rem;
		line-height: 1.7;
		color: var(--text-secondary);
	}

	.book-section + .book-section {
		margin-top: var(--space-xl);
	}

	.book-section__label {
		font-size: 0.6875rem;
		letter-spacing: 0.04em;
		color: var(--text-disabled);
		margin-bottom: var(--space-sm);
	}

	.book-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
		max-width: 56ch;
	}

	.book-list__item {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: var(--space-xs) var(--space-lg);
		align-items: baseline;
		padding: var(--space-sm) 0;
		border-bottom: 1px solid var(--border);
		font-size: 0.9375rem;
		line-height: 1.5;
	}

	.book-list__item:last-child {
		border-bottom: none;
	}

	.book-list__title {
		color: var(--text-primary);
	}

	.book-list__author {
		font-size: 0.6875rem;
		letter-spacing: 0.03em;
		color: var(--text-secondary);
		white-space: nowrap;
	}

	.book-list__note {
		grid-column: 1 / -1;
		font-size: 0.8125rem;
		color: var(--text-disabled);
	}

	@media (max-width: 540px) {
		.book-list__item {
			grid-template-columns: 1fr;
			gap: var(--space-2xs);
		}

		.book-list__author {
			white-space: normal;
		}
	}
</style>
